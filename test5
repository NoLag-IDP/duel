local function makeQuickBtn(label, icon, yOff, colorOn, activateFn, deactivateFn, stateKey)
    local btn = Instance.new("TextButton", QB)
    btn.Size = UDim2.new(1,-10,0,QB_BTN_H)
    btn.Position = UDim2.new(0,5,0,yOff)
    btn.BackgroundColor3 = C.Panel
    btn.BorderSizePixel = 0; btn.Text = ""
    btn.AutoButtonColor = false; btn.ZIndex = 302
    mkC(btn, 7)

    local glow = Instance.new("UIStroke", btn)
    glow.Color = colorOn; glow.Thickness = 1.5; glow.Transparency = 1

    -- left accent bar
    local bar = Instance.new("Frame", btn)
    bar.Size = UDim2.new(0,3,0,22); bar.Position = UDim2.new(0,0,0.5,-11)
    bar.BackgroundColor3 = colorOn; bar.BackgroundTransparency = 1
    bar.BorderSizePixel = 0; bar.ZIndex = 304; mkC(bar,2)

    -- icon top
    local ico = Instance.new("TextLabel", btn)
    ico.Size = UDim2.new(1,0,0,18); ico.Position = UDim2.new(0,0,0,4)
    ico.BackgroundTransparency = 1; ico.Text = icon
    ico.TextColor3 = C.SubText; ico.TextSize = 13
    ico.Font = Enum.Font.GothamBlack; ico.ZIndex = 303

    -- label
    local lbl = Instance.new("TextLabel", btn)
    lbl.Size = UDim2.new(1,0,0,11); lbl.Position = UDim2.new(0,0,0,22)
    lbl.BackgroundTransparency = 1; lbl.Text = label
    lbl.TextColor3 = C.SubText; lbl.TextSize = 7
    lbl.Font = Enum.Font.GothamBlack; lbl.ZIndex = 303

    -- toggle switch bottom
    local swO = Instance.new("Frame", btn)
    swO.Size = UDim2.new(0,28,0,13); swO.Position = UDim2.new(0.5,-14,1,-16)
    swO.BackgroundColor3 = C.SW_Off; swO.BorderSizePixel = 0
    swO.ZIndex = 304; mkC(swO, 6)

    local swK = Instance.new("Frame", swO)
    swK.Size = UDim2.new(0,10,0,10); swK.Position = UDim2.new(0,2,0.5,-5)
    swK.BackgroundColor3 = C.SW_Knob; swK.BorderSizePixel = 0
    swK.ZIndex = 305; mkC(swK, 5)

    local on = false
    local function refresh(forceVal)
        if forceVal ~= nil then on = forceVal end
        TweenService:Create(swK, TweenInfo.new(0.1), {
            Position = on and UDim2.new(0,16,0.5,-5) or UDim2.new(0,2,0.5,-5),
            BackgroundColor3 = on and colorOn or C.SW_Knob
        }):Play()
        swO.BackgroundColor3 = on and Color3.fromRGB(20,18,6) or C.SW_Off
        if on then
            btn.BackgroundColor3 = Color3.fromRGB(18,16,5)
            glow.Transparency = 0.15
            bar.BackgroundTransparency = 0.2
            ico.TextColor3 = colorOn
            lbl.TextColor3 = C.White
        else
            btn.BackgroundColor3 = C.Panel
            glow.Transparency = 1
            bar.BackgroundTransparency = 1
            ico.TextColor3 = C.SubText
            lbl.TextColor3 = C.SubText
        end
    end

    if stateKey then
        local prev = btnRefreshFns[stateKey]
        btnRefreshFns[stateKey] = function(v)
            if prev then prev(v) end; refresh(v)
        end
    end

    btn.MouseButton1Click:Connect(function()
        on = not on; refresh()
        if on then if activateFn then activateFn() end
        else if deactivateFn then deactivateFn() end end
    end)

    return refresh
end


-- hasGearBtn items go full-width (left col only, no column advance)
local function toggleBtn(label, keyText, callback, hasGearBtn, gearSide, stateKey)
    local cx = colX()
    local bw = COL_W
    -- gear buttons always full row
    if hasGearBtn then cx = 6; bw = COL_W * 2 + COL_GAP end

    local row = Instance.new("Frame")
    row.Size = UDim2.new(0, bw, 0, 30)
    row.Position = UDim2.new(0, cx, 0, yPos)
    row.BackgroundColor3 = C.Panel
    row.BorderSizePixel = 0
    row.ZIndex = 203
    row.Parent = Scroll
    mkC(row, 5)

    -- key badge
    local labelX = 8
    if keyText ~= "" then
        local badge = Instance.new("TextLabel", row)
        badge.Size = UDim2.new(0, 20, 0, 14)
        badge.Position = UDim2.new(0, 6, 0.5, -7)
        badge.BackgroundColor3 = C.GoldFaint
        badge.BorderSizePixel = 0
        badge.Text = keyText
        badge.TextSize = 8
        badge.TextColor3 = C.Gold
        badge.Font = Enum.Font.GothamBlack
        badge.ZIndex = 205
        badge.Parent = row
        mkC(badge, 3)
        labelX = 30
    end

    local rightPad = hasGearBtn and 56 or 44
    local lbl = Instance.new("TextLabel", row)
    lbl.Size = UDim2.new(1, -(labelX + rightPad), 1, 0)
    lbl.Position = UDim2.new(0, labelX, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = label
    lbl.TextColor3 = C.SubText
    lbl.TextSize = 10
    lbl.Font = Enum.Font.Gotham
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.ZIndex = 204
    lbl.Parent = row

    -- gear button
    if hasGearBtn then
        local gBtn = Instance.new("TextButton", row)
        gBtn.Size = UDim2.new(0, 20, 0, 20)
        gBtn.Position = UDim2.new(1, -44, 0.5, -10)
        gBtn.BackgroundColor3 = Color3.fromRGB(16,16,20)
        gBtn.BorderSizePixel = 0
        gBtn.Text = "⚙"
        gBtn.TextColor3 = C.CyanDim
        gBtn.TextSize = 11
        gBtn.Font = Enum.Font.Gotham
        gBtn.ZIndex = 206
        gBtn.Parent = row
        mkC(gBtn, 4)
        mkS(gBtn, C.CyanDim, 1, 0.4)
        gBtn.MouseButton1Click:Connect(function() openWPPanel(gearSide) end)
    end

    -- Toggle switch (like reference image)
    local swO = Instance.new("Frame", row)
    swO.Size = UDim2.new(0, 32, 0, 16)
    swO.Position = UDim2.new(1, -38, 0.5, -8)
    swO.BackgroundColor3 = C.SW_Off
    swO.BorderSizePixel = 0
    swO.ZIndex = 205
    swO.Parent = row
    mkC(swO, 8)

    local swK = Instance.new("Frame", swO)
    swK.Size = UDim2.new(0, 12, 0, 12)
    swK.Position = UDim2.new(0, 2, 0.5, -6)
    swK.BackgroundColor3 = C.SW_Knob
    swK.BorderSizePixel = 0
    swK.ZIndex = 206
    swK.Parent = swO
    mkC(swK, 6)

    local swBtn = Instance.new("TextButton", row)
    swBtn.Size = UDim2.new(1, 0, 1, 0)
    swBtn.BackgroundTransparency = 1
    swBtn.Text = ""
    swBtn.ZIndex = 207
    swBtn.Parent = row

    local on = false
    local function refresh(forceVal)
        if forceVal ~= nil then on = forceVal end
        TweenService:Create(swK, TweenInfo.new(0.1), {
            Position = on and UDim2.new(0,18,0.5,-6) or UDim2.new(0,2,0.5,-6),
            BackgroundColor3 = on and C.Gold or C.SW_Knob
        }):Play()
        swO.BackgroundColor3 = on and C.GoldFaint or C.SW_Off
        lbl.TextColor3 = on and C.White or C.SubText
    end

    if stateKey then btnRefreshFns[stateKey] = refresh end
    swBtn.MouseButton1Click:Connect(function() on = not on; refresh(); if callback then callback(on) end end)
    swBtn.MouseButton2Click:Connect(function() on = false; refresh(); if callback then callback(false) end end)

    -- advance column
    if hasGearBtn then
        colTrack = 0  -- full-width rows reset to left
        yPos = yPos + 34
    else
        if colTrack == 0 then
            colTrack = 1  -- move to right next
        else
            colTrack = 0
            yPos = yPos + 34  -- both cols filled, next row
        end
    end
end

